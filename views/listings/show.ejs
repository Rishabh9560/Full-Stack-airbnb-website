<%layout("/layouts/boilerplate")%>
<div class="row mt-3">
    <div class="col-8 offset-3" >
    <h3><%=listing.title%></h3>
   </div>

    <div class="card col-6 offset-3 show-card">
    <img src="<%=listing.image%>" class="card-img-top show-img" alt="Listing image">
    <div class="card-body">
    <!-- <b><p class="card-text"><%=listing.title%></b><br> -->
       <%=listing.description%><br>
       &#x20B9; <%=listing.price.toLocaleString("en-IN")%> <br> <!--function is use to show the price in indian standard-->
        <%=listing.country%><br>
        <%=listing.location%><br>
    </p>
    </div>
    </div>


  

    <div class="btns">
        <a href="/listings/<%=listing.id%>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
        <form method="POST" action="/listings/<%=listing.id%>?_method=DELETE">
            <button class="btn btn-dark  offset-5">Delete</button>
        </form>
    </div>
    <hr>
    <div class="col-8 offset-3 mb-3">
        <h4>Leave a Review </h4>
        <form>
            <div class="mb-3 mt-3 ">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
                
            </div>
            <div>
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="10" class="form-control"></textarea>
            </div>
            <button class="btn btn-dark mt-3">Submit</button>
        </form>

    </div>
</div>


