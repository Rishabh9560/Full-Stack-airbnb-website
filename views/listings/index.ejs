<% layout("/layouts/boilerplate")%> 
<style>
  #filters  {
    display: flex;
    flex-wrap: wrap;
    align-items: center;


  }
 
  #filter {
    text-align: center;
    margin-right: 2rem;
    margin-top: 2rem;
    opacity: 0.7;
  }
  #filter:hover{
    opacity:1 ;
    cursor:pointer ;
  }
  #filter{
    font-size: 1rem;

  }
  .tax-info{
    display: none;
  }
  .tax-toogle{
    padding: 1rem;
    border: 1px solid black;
    height:3.5rem ; 
    border-radius: 1rem;
    margin-left: 3rem;
    display: flex;
    align-items: center;


  }
</style>

<!-- 
