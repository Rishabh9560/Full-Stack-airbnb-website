        <p>Iconic Cities</p>

      </div>
      <div id="filter">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>

      </div>
      
      <div id="filter">
        <div><i class="fa-solid fa-snowflake"></i></i></div>
        <p>Arctic</p>

      </div>
      <div id="filter">
        <div><i class="fa-solid fa-house-flag"></i></div>
        <p>Camping</p>

      </div>
       <div id="filter">
        <div><i class="fa-solid fa-tractor"></i>></div>
        <p>Farms</p>

      </div>
      <div id="filter">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Pools</p>

      </div>
