<% layout("/layouts/boilerplate")%>
<body>
    <h1>All Listings</h1>
    <!--<form method="GET" action="/listings/new">
        <button>Create new Listings</button>
       
    </form>-->
    <div class="row row-cols-lg-3  row-cols-sm-1 row-cols-md-2">
    <%for(let listing of allListings){%>
        <a href="/listings/<%=listing.id%>" class="listing-links">
     <div class="card col" >
  <img src="<%=listing.image%>" class="card-img-top" alt="listing image" style="height:20rem">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <b><p class="card-text"><%=listing.title%></b>
    <br>
&#x20B9; <%=listing.price.toLocaleString("en-IN")%> / night</p>
  </div>
</div>
</a>
  <%}%>
    </div>
