    <div id="filters">
      <div id="filter">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>

      </div>
      <div id="filter">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Room</p>

      </div>
      <div id="filter">
